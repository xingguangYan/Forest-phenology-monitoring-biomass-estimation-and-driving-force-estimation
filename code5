        "\n",
        "# ======================= 1. 全局配置 =======================\n",
        "roi = ee.FeatureCollection(\"projects/my-project-paper-462110/assets/wuhan_samples_2024\")  # 样本点集合\n",
        "index_name = 'NIRv'          # 可选 'NDVI', 'EVI', 'GCC', 'NIRv'\n",
        "smooth_window_days = 15      # 平滑窗口（天）\n",
        "years = list(range(2000, 2025))  # 2000–2024\n",
        "\n",
        "# ======================= 2. 函数定义 =======================\n",
        "def mask_modis_clouds(image):\n",
        "    \"\"\"\n",
        "    MOD09A1 云掩膜：基于 QA 波段\n",
        "    参考 MODIS/061/MOD09A1 'QA' band definition\n",
        "    bit0: Cloud State (0=Clear)\n",
        "    bit1: Cloud Shadow (0=No Cloud Shadow)\n",
        "    bit3: Snow/Ice (0=No Snow/Ice)\n",
        "    \"\"\"\n",
        "    state = image.select('QA') # Changed from 'state_1km' to 'QA'\n",
        "    cloud = state.bitwiseAnd(1 << 0).eq(0)        # 无云 (Clear)\n",
        "    cloudShadow = state.bitwiseAnd(1 << 1).eq(0)  # 无云阴影\n",
        "    snowIce = state.bitwiseAnd(1 << 3).eq(0)      # 无雪/冰\n",
        "    mask = cloud.And(cloudShadow).And(snowIce)\n",
        "    # 反射率缩放：原始值 0–10000，除以 10000 得到真实反射率\n",
        "    scaled = image.select(['sur_refl_b01', 'sur_refl_b02', 'sur_refl_b03',\n",
        "                           'sur_refl_b04', 'sur_refl_b05', 'sur_refl_b06', 'sur_refl_b07']) \\\n",
        "                  .divide(10000).rename(['B1', 'B2', 'B3', 'B4', 'B5', 'B6', 'B7'])\n",
        "    return image.addBands(scaled, overwrite=True).updateMask(mask) \\\n",
        "                .copyProperties(image, ['system:time_start'])\n",
        "\n",
        "def add_indices(image):\n",
        "    \"\"\"添加植被指数（波段名 B1:红, B2:近红外, B3:蓝, B4:绿, B6:短波红外）\"\"\"\n",
        "    blue = image.select('B3')\n",
        "    green = image.select('B4')\n",
        "    red = image.select('B1')\n",
        "    nir = image.select('B2')\n",
        "    swir1 = image.select('B6')       # 短波红外，用于 NDPI\n",
        "    ndvi = image.normalizedDifference(['B2', 'B1']).rename('NDVI')\n",
        "    evi = image.expression('2.5 * ((NIR - RED) / (NIR + 6 * RED - 7.5 * BLUE + 1))',\n",
        "                           {'NIR': nir, 'RED': red, 'BLUE': blue}).rename('EVI')\n",
        "    gcc = green.divide(red.add(green).add(blue)).rename('GCC')\n",
        "    ndpi = image.normalizedDifference(['B2', 'B6']).rename('NDPI')\n",
        "    nirv = ndvi.multiply(nir).rename('NIRv')\n",
        "    return image.addBands([ndvi, evi, gcc, ndpi, nirv])\n",
        "\n",
        "def add_doy(image):\n",
        "    \"\"\"添加日序数（Day of Year, 1-366）\"\"\"\n",
        "    doy = ee.Date(image.get('system:time_start')).getRelative('day', 'year').add(1)\n",
        "    return image.addBands(ee.Image.constant(doy).rename('DOY').float())\n",
        "\n",
        "def temporal_smooth(collection, window_days, band_names, start_date, end_date):\n",
        "    \"\"\"\n",
        "    对 ImageCollection 进行时间窗口平均平滑\n",
        "    返回一个新的 ImageCollection，每个影像代表窗口内的均值\n",
        "    \"\"\"\n",
        "    start = ee.Date(start_date)\n",
        "    end = ee.Date(end_date)\n",
        "    n_intervals = end.difference(start, 'day').divide(window_days).ceil()\n",
        "    dates = ee.List.sequence(0, n_intervals.subtract(1))\n",
        "    def composite(n):\n",
        "        t_start = start.advance(ee.Number(n).multiply(window_days), 'day')\n",
        "        t_end = t_start.advance(window_days, 'day')\n",
        "        col_window = collection.filterDate(t_start, t_end).select(band_names)\n",
        "\n",
        "        # Create a zero image with float bands\n",
        "        zero_bands = ee.Image.constant(ee.List.repeat(0, len(band_names))).rename(band_names).float()\n",
        "\n",
        "        # Calculate mean image, ensuring all bands are float\n",
        "        mean_img_with_float_bands = ee.Image(ee.Algorithms.If(\n",
        "            col_window.size().gt(0),\n",
        "            col_window.mean().float(),  # Explicitly cast to float\n",
        "            zero_bands\n",
        "        ))\n",
        "\n",
        "        mid_date = t_start.advance(window_days/2, 'day')\n",
        "        doy = mid_date.getRelative('day', 'year').add(1)\n",
        "        doy_img = ee.Image.constant(doy).rename('DOY').float()\n",
        "\n",
        "        return mean_img_with_float_bands.addBands(doy_img) \\\n",
        "                       .set('system:time_start', mid_date.millis())\n",
        "    return ee.ImageCollection.fromImages(dates.map(composite))\n",
        "\n",
        "def extract_phenology(smoothed_col, index_name):\n",
        "    \"\"\"\n",
        "    基于平滑后的影像集合提取物候参数\n",
        "    返回一个包含 SOS, POS, EOS, LOS 四个波段的图像（缺失波段用 NaN 填充）\n",
        "    \"\"\"\n",
        "    def nan_img(band):\n",
        "        return ee.Image.constant(ee.Number(0)).divide(0).rename(band).float()\n",
        "\n",
        "    index_max = smoothed_col.select(index_name).reduce(ee.Reducer.max())\n",
        "    index_min = smoothed_col.select(index_name).reduce(ee.Reducer.min())\n",
        "    threshold = index_min.add(index_max.subtract(index_min).multiply(0.3))\n",
        "\n",
        "    pos_raw = smoothed_col.qualityMosaic(index_name).select('DOY')\n",
        "    pos_doy = ee.Image(ee.Algorithms.If(pos_raw.bandNames().size().eq(0),\n",
        "                                        nan_img('POS'),\n",
        "                                        pos_raw.rename('POS')))\n",
        "\n",
        "    def get_sos(img):\n",
        "        cond = img.select(index_name).gt(threshold).And(img.select('DOY').lt(pos_doy))\n",
        "        return img.select('DOY').updateMask(cond)\n",
        "    sos_raw = smoothed_col.map(get_sos).reduce(ee.Reducer.min())\n",
        "    sos_doy = ee.Image(ee.Algorithms.If(sos_raw.bandNames().size().eq(0),\n",
        "                                        nan_img('SOS'),\n",
        "                                        sos_raw.rename('SOS')))\n",
        "\n",
        "    def get_eos(img):\n",
        "        cond = img.select(index_name).gt(threshold).And(img.select('DOY').gt(pos_doy))\n",
        "        return img.select('DOY').updateMask(cond)\n",
        "    eos_raw = smoothed_col.map(get_eos).reduce(ee.Reducer.max())\n",
        "    eos_doy = ee.Image(ee.Algorithms.If(eos_raw.bandNames().size().eq(0),\n",
        "                                        nan_img('EOS'),\n",
        "                                        eos_raw.rename('EOS')))\n",
        "\n",
        "    los = eos_doy.subtract(sos_doy).rename('LOS')\n",
        "    result = ee.Image.cat([sos_doy, pos_doy, eos_doy, los])\n",
        "    # 确保有四个波段\n",
        "    result = ee.Image(ee.Algorithms.If(result.bandNames().size().eq(4),\n",
        "                                       result,\n",
        "                                       ee.Image.cat([nan_img('SOS'), nan_img('POS'),\n",
        "                                                     nan_img('EOS'), nan_img('LOS')])))\n",
        "    return result\n",
        "\n",
        "def process_year(year):\n",
        "    \"\"\"处理单一年份，返回该年份各样本点的物候参数 DataFrame\"\"\"\n",
        "    start_date = f\"{year}-01-01\"\n",
        "    end_date = f\"{year}-12-31\"\n",
        "\n",
        "    raw_col = (ee.ImageCollection('MODIS/061/MOD09A1')\n",
        "               .filterBounds(roi)\n",
        "               .filterDate(start_date, end_date)\n",
        "               .map(mask_modis_clouds)\n",
        "               .map(add_indices)\n",
        "               .map(add_doy))\n",
        "\n",
        "    indices_list = ['NDVI', 'EVI', 'GCC', 'NDPI', 'NIRv']\n",
        "    smooth_col = temporal_smooth(raw_col, smooth_window_days, indices_list + ['DOY'],\n",
        "                                 start_date, end_date)\n",
        "\n",
        "    pheno_raw = extract_phenology(smooth_col, index_name)\n",
        "    pheno_image = pheno_raw.rename([f\"{index_name}_{p}\" for p in ['SOS', 'POS', 'EOS', 'LOS']])\n",
        "\n",
        "    def extract_at_points(f):\n",
        "        geom = f.geometry()\n",
        "        vals = pheno_image.reduceRegion(reducer=ee.Reducer.first(), geometry=geom,\n",
        "                                        scale=500, bestEffort=True, tileScale=4)\n",
        "        return f.set(vals).set({'lon': geom.coordinates().get(0), 'lat': geom.coordinates().get(1)})\n",
        "\n",
        "    results_fc = roi.map(extract_at_points)\n",
        "    # 获取属性列表\n",
        "    features = results_fc.getInfo()['features']\n",
        "    rows = []\n",
        "    for f in features:\n",
        "        props = f['properties']\n",
        "        row = {\n",
        "            'year': year,\n",
        "            'lon': props.get('lon'),\n",
        "            'lat': props.get('lat'),\n",
        "            f\"{index_name}_SOS\": props.get(f\"{index_name}_SOS\"),\n",
        "            f\"{index_name}_POS\": props.get(f\"{index_name}_POS\"),\n",
        "            f\"{index_name}_EOS\": props.get(f\"{index_name}_EOS\"),\n",
        "            f\"{index_name}_LOS\": props.get(f\"{index_name}_LOS\"),\n",
        "        }\n",
        "        rows.append(row)\n",
        "    df_year = pd.DataFrame(rows)\n",
        "    # 转换为数值\n",
        "    for col in [f\"{index_name}_{p}\" for p in ['SOS', 'POS', 'EOS', 'LOS']]:\n",
        "        df_year[col] = pd.to_numeric(df_year[col], errors='coerce')\n",
        "    return df_year\n",
        "\n",
        "# ======================= 3. 逐年处理并汇总 =======================\n",
        "all_dfs = []\n",
        "for yr in years:\n",
        "    print(f\"Processing {yr}...\")\n",
        "    df_yr = process_year(yr)\n",
        "    all_dfs.append(df_yr)\n",
        "    print(f\"  -> {len(df_yr)} samples\")\n",
        "\n",
        "df_total = pd.concat(all_dfs, ignore_index=True)\n",
        "\n",
        "# ======================= 4. 输出结果 =======================\n",
        "# 按年份排序\n",
        "df_total = df_total.sort_values(['year', 'lat', 'lon']).reset_index(drop=True)\n",
        "\n",
        "# 保存到 Excel 和 CSV\n",
        "df_total.to_excel('phenology_2000_2024.xlsx', index=False, engine='openpyxl')\n",
        "df_total.to_csv('phenology_2000_2024.csv', index=False)\n",
        "\n",
        "# 显示前几行和统计\n",
        "print(\"\\n========== 汇总表格预览 ==========\")\n",
        "print(tabulate(df_total.head(20), headers='keys', tablefmt='grid', showindex=False))\n",
        "\n",
        "print(f\"\\n总记录数: {len(df_total)}\")\n",
        "print(\"结果已保存至 phenology_2000_2024.xlsx 和 phenology_2000_2024.csv\")\n",
        "\n",
        "# 可选：输出各年份平均值统计\n",
        "stats = df_total.groupby('year')[ [f\"{index_name}_{p}\" for p in ['SOS', 'POS', 'EOS', 'LOS']] ].mean().round(1)\n",
        "stats.to_excel('phenology_yearly_stats.xlsx')\n",
        "print(\"\\n各年份平均物候参数已保存至 phenology_yearly_stats.xlsx\")\n",
        "print(stats)"
