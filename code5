        "import ee\n",
        "\n",
        "# 1. Define list of vegetation index band names to be smoothed\n",
        "indices_list = ['NDVI', 'EVI', 'GCC', 'NDPI', 'NIRv']\n",
        "\n",
        "# 2. Create the temporal_smooth function\n",
        "def temporal_smooth(collection, window_days, band_names):\n",
        "    # 3. Define sequence of dates for 2022\n",
        "    start = ee.Date('2023-01-01')\n",
        "    end = ee.Date('2023-12-31')\n",
        "    n_intervals = end.difference(start, 'day').divide(window_days).ceil()\n",
