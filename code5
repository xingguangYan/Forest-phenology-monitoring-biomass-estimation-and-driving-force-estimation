        "import ee\n",
        "import pandas as pd\n",
        "from tabulate import tabulate\n",
        "\n",
        "# ======================= 0. 初始化 Earth Engine =======================\n",
        "try:\n",
        "    ee.Initialize(project='ee-bqt2000204051')\n",
        "except Exception:\n",
        "    ee.Authenticate()\n",
        "    ee.Initialize(project='ee-bqt2000204051')\n",
        "\n",
        "# ======================= 1. 全局配置 =======================\n",
        "# 样本点集合\n",
        "roi = ee.FeatureCollection(\"projects/my-project-paper-462110/assets/wuhan_samples_2024\")\n",
        "index_name = 'NIRv'          # 目标物候提取指数\n",
        "smooth_window_days = 15      # 时间平滑窗口（天）\n",
        "# 注意：HLS-S30 数据建议从 2017 年开始，早期数据可能缺失严重\n",
        "years = list(range(2017, 2025))\n",
        "\n",
        "# ======================= 2. 辅助函数 =======================\n",
        "\n",
        "def mask_hls_clouds(image):\n",
        "    \"\"\"HLS-S30 云掩膜及反射率缩放\"\"\"\n",
        "    fmask = image.select('Fmask')\n",
        "    # 位掩码：剔除云阴影(bit1)、云(bit2)、雪冰(bit3)\n",
        "    mask = fmask.bitwiseAnd(1 << 1).eq(0) \\\n",
        "                .And(fmask.bitwiseAnd(1 << 2).eq(0)) \\\n",
        "                .And(fmask.bitwiseAnd(1 << 3).eq(0))\n",
        "    return image.updateMask(mask).divide(10000).copyProperties(image, ['system:time_start'])\n",
        "\n",
        "def add_indices(image):\n",
        "    \"\"\"计算各类植被指数\"\"\"\n",
        "    nir = image.select('B8')\n",
        "    red = image.select('B4')\n",
        "    blue = image.select('B2')\n",
        "    green = image.select('B3')\n",
        "\n",
        "    # NDVI 与 NIRv (NDVI * NIR)\n",
        "    ndvi = image.normalizedDifference(['B8', 'B4']).rename('NDVI')\n",
        "    nirv = ndvi.multiply(nir).rename('NIRv')\n",
        "\n",
        "    # 其他常用指数\n",
        "    evi = image.expression(\n",
        "        '2.5 * ((NIR - RED) / (NIR + 6 * RED - 7.5 * BLUE + 1))',\n",
        "        {'NIR': nir, 'RED': red, 'BLUE': blue}\n",
        "    ).rename('EVI')\n",
        "    gcc = green.divide(red.add(green).add(blue)).rename('GCC')\n",
        "    ndpi = image.normalizedDifference(['B8', 'B11']).rename('NDPI')\n",
        "\n",
        "    return image.addBands([ndvi, nirv, evi, gcc, ndpi])\n",
        "\n",
        "def filter_by_ndvi_delta(collection, region):\n",
        "    \"\"\"\n",
        "    质量控制：剔除相邻影像 NDVI 均值差异超过 0.5 的异常观测\n",
        "    \"\"\"\n",
        "    def add_mean(img):\n",
        "        m = img.select('NDVI').reduceRegion(\n",
        "            reducer=ee.Reducer.mean(),\n",
        "            geometry=region.geometry(),\n",
        "            scale=100,\n",
        "            maxPixels=1e9\n",
        "        ).get('NDVI')\n",
        "        return img.set('ndvi_mean', m)\n",
        "\n",
        "    # 计算每期均值并转为列表用于迭代对比\n",
        "    col_with_mean = collection.map(add_mean).sort('system:time_start')\n",
        "    col_list = col_with_mean.toList(col_with_mean.size())\n",
        "\n",
        "    def check_delta(img):\n",
        "        img = ee.Image(img)\n",
        "        curr_ndvi = ee.Number(img.get('ndvi_mean'))\n",
        "\n",
        "        # 获取前一期影像索引，首期与自身对比\n",
        "        prev_idx = col_list.indexOf(img).subtract(1).max(0)\n",
        "        prev_img = ee.Image(col_list.get(prev_idx))\n",
        "        prev_ndvi = ee.Number(prev_img.get('ndvi_mean'))\n",
        "\n",
        "        delta = curr_ndvi.subtract(prev_ndvi).abs()\n",
        "        # 标记差异 > 0.5 的为离群点 (outlier)\n",
        "        return img.set('ndvi_delta', delta).set('is_outlier', delta.gt(0.5))\n",
        "\n",
        "    processed = col_with_mean.map(check_delta)\n",
        "    # 过滤掉异常影像，并确保均值有效（>0）\n",
        "    return processed.filter(ee.Filter.eq('is_outlier', 0)).filter(ee.Filter.gt('ndvi_mean', 0))\n",
        "\n",
        "def temporal_smooth(collection, window_days, band_names, start_date, end_date):\n",
        "    \"\"\"时间窗口平滑函数\"\"\"\n",
        "    start = ee.Date(start_date)\n",
        "    end = ee.Date(end_date)\n",
        "    n_intervals = end.difference(start, 'day').divide(window_days).ceil()\n",
        "    dates = ee.List.sequence(0, n_intervals.subtract(1))\n",
        "\n",
        "    def composite(n):\n",
        "        t_start = start.advance(ee.Number(n).multiply(window_days), 'day')\n",
        "        t_end = t_start.advance(window_days, 'day')\n",
        "        col_window = collection.filterDate(t_start, t_end).select(band_names)\n",
        "\n",
        "        zero_img = ee.Image.constant(ee.List.repeat(0, len(band_names))) \\\n",
        "                           .rename(band_names).unmask(0).float()\n",
        "        mean_img = col_window.mean().unmask(0).float()\n",
        "\n",
        "        final_img = ee.Image(ee.Algorithms.If(col_window.size().gt(0), mean_img, zero_img))\n",
        "\n",
        "        mid_date = t_start.advance(window_days/2, 'day')\n",
        "        doy = mid_date.getRelative('day', 'year').add(1)\n",
        "        return final_img.addBands(ee.Image.constant(doy).rename('DOY').float()) \\\n",
        "                        .set('system:time_start', mid_date.millis())\n",
        "\n",
        "    return ee.ImageCollection.fromImages(dates.map(composite))\n",
        "\n",
        "def extract_phenology(smoothed_col, idx):\n",
        "    \"\"\"基于动态阈值法提取物候关键参数\"\"\"\n",
        "    idx_max = smoothed_col.select(idx).reduce(ee.Reducer.max())\n",
        "    idx_min = smoothed_col.select(idx).reduce(ee.Reducer.min())\n",
        "    # 20% 阈值\n",
        "    threshold = idx_min.add(idx_max.subtract(idx_min).multiply(0.2))\n",
        "\n",
        "    # POS: 峰值日期\n",
        "    pos_raw = smoothed_col.qualityMosaic(idx).select('DOY')\n",
        "    pos_doy = ee.Image(ee.Algorithms.If(pos_raw.bandNames().size().gt(0),\n",
        "                                       pos_raw.rename('POS'),\n",
        "                                       ee.Image.constant(0).divide(0).rename('POS')))\n",
        "\n",
        "    # SOS: 峰值前首次越过阈值\n",
        "    def get_sos(img):\n",
        "        cond = img.select(idx).gt(threshold).And(img.select('DOY').lt(pos_doy))\n",
        "        return img.select('DOY').updateMask(cond)\n",
        "    sos_doy = smoothed_col.map(get_sos).reduce(ee.Reducer.min()).rename('SOS')\n",
        "\n",
        "    # EOS: 峰值后最后一次高于阈值\n",
        "    def get_eos(img):\n",
        "        cond = img.select(idx).gt(threshold).And(img.select('DOY').gt(pos_doy))\n",
        "        return img.select('DOY').updateMask(cond)\n",
        "    eos_doy = smoothed_col.map(get_eos).reduce(ee.Reducer.max()).rename('EOS')\n",
        "\n",
        "    los = eos_doy.subtract(sos_doy).rename('LOS')\n",
        "    return ee.Image.cat([sos_doy, pos_doy, eos_doy, los])\n",
        "\n",
        "def extract_at_points(fc, image, scale=30):\n",
        "    \"\"\"结果提取到 Pandas DataFrame\"\"\"\n",
        "    def get_values(f):\n",
        "        geom = f.geometry()\n",
        "        coords = geom.coordinates()\n",
        "        val = image.reduceRegion(ee.Reducer.first(), geom, scale, tileScale=8)\n",
        "        return f.set('lon', coords.get(0)).set('lat', coords.get(1)).set(val)\n",
        "\n",
        "    features = fc.map(get_values).getInfo()['features']\n",
        "    return pd.DataFrame([f['properties'] for f in features])\n",
        "\n",
        "# ======================= 3. 主循环逻辑 =======================\n",
        "def process_year(year):\n",
        "    start_date = f\"{year}-01-01\"\n",
        "    end_date = f\"{year}-12-31\"\n",
        "    print(f\"--- Processing Year: {year} ---\")\n",
        "\n",
        "    raw_col = (ee.ImageCollection(\"NASA/HLS/HLSS30/v002\")\n",
        "               .filterBounds(roi)\n",
        "               .filterDate(start_date, end_date)\n",
        "               .map(mask_hls_clouds)\n",
        "               .map(add_indices))\n",
        "\n",
        "    if raw_col.size().getInfo() == 0:\n",
        "        print(f\"  No data available for {year}.\")\n",
        "        return None\n",
        "\n",
        "    # 1. 异常值剔除 (NDVI Delta > 0.5)\n",
        "    clean_col = filter_by_ndvi_delta(raw_col, roi)\n",
        "\n",
        "    orig_cnt = raw_col.size().getInfo()\n",
        "    clean_cnt = clean_col.size().getInfo()\n",
        "    print(f\"  Quality Control: {orig_cnt} -> {clean_cnt} images (Removed {orig_cnt - clean_cnt})\")\n",
        "\n",
        "    if clean_cnt < 5:\n",
        "        print(f\"  Skipping {year}: Insufficient valid images.\")\n",
        "        return None\n",
        "\n",
        "    # 2. 时间平滑\n",
        "    indices_to_smooth = ['NDVI', 'EVI', 'GCC', 'NDPI', 'NIRv']\n",
        "    smooth_col = temporal_smooth(clean_col, smooth_window_days, indices_to_smooth, start_date, end_date)\n",
        "\n",
        "    # 3. 提取 NIRv 物候参数\n",
        "    pheno_img = extract_phenology(smooth_col, index_name)\n",
        "    pheno_img = pheno_img.rename([f\"{index_name}_{p}\" for p in ['SOS', 'POS', 'EOS', 'LOS']])\n",
        "\n",
        "    # 4. 采集点位数据\n",
        "    df = extract_at_points(roi, pheno_img, scale=30)\n",
        "    df['year'] = year\n",
        "    return df\n",
        "\n",
        "# ======================= 4. 执行与结果保存 =======================\n",
        "final_dfs = []\n",
        "for yr in years:\n",
        "    try:\n",
        "        yr_data = process_year(yr)\n",
        "        if yr_data is not None:\n",
        "            final_dfs.append(yr_data)\n",
        "    except Exception as e:\n",
        "        print(f\"  Error in {yr}: {e}\")\n",
        "\n",
        "if final_dfs:\n",
        "    df_result = pd.concat(final_dfs, ignore_index=True)\n",
        "\n",
        "    # 基础清洗：剔除无物候值的行\n",
        "    pheno_cols = [f\"{index_name}_{p}\" for p in ['SOS', 'EOS']]\n",
        "    df_clean = df_result.dropna(subset=pheno_cols)\n",
        "\n",
        "    # 保存结果\n",
        "    output_csv = 'phenology_NIRv_HLS_Wuhan.csv'\n",
        "    df_clean.to_csv(output_csv, index=False)\n",
        "\n",
        "    print(\"\\n\" + \"=\"*40)\n",
        "    print(f\"Processing Complete! Results saved to: {output_csv}\")\n",
        "    print(\"=\"*40)\n",
        "\n",
