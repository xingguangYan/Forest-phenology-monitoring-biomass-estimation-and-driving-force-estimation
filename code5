        "\n",
        "# 2. Define Cloud Masking Function\n",
        "def mask_hls_clouds(image):\n",
        "    # HLS (HLSS30) Fmask bits: bit1: cloud, bit2: cloud shadow, bit3: snow/ice\n",
        "    fmask = image.select('Fmask')\n",
        "    cloud = fmask.bitwiseAnd(1 << 1).eq(0)\n",
        "    cloudShadow = fmask.bitwiseAnd(1 << 2).eq(0)\n",
        "    snowIce = fmask.bitwiseAnd(1 << 3).eq(0)\n",
        "    mask = cloud.And(cloudShadow).And(snowIce)\n",
        "    # Scale bands to reflectance (0-1) and keep properties\n",
        "    return image.updateMask(mask).divide(10000).copyProperties(image, ['system:time_start'])\n",
        "\n",
        "# 3. Define Index Calculation Function\n",
        "def add_indices(image):\n",
        "    # Map bands to standard names\n",
        "    blue = image.select('B2')\n",
        "    green = image.select('B3')\n",
        "    red = image.select('B4')\n",
        "    nir = image.select('B8')\n",
        "    swir1 = image.select('B11')\n",
        "\n",
        "    # Calculate Indices\n",
        "    ndvi = image.normalizedDifference(['B8', 'B4']).rename('NDVI')\n",
