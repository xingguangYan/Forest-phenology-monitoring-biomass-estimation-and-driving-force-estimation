        "def extract_at_points(fc, image, scale=30):\n",
        "    \"\"\"提取每个样本点在指定影像上的值，返回 Pandas DataFrame，包含坐标\"\"\"\n",
        "    def get_values(f):\n",
        "        geom = f.geometry()\n",
        "        coords = geom.coordinates()\n",
        "        lon = coords.get(0)\n",
        "        lat = coords.get(1)\n",
        "        pt = ee.Geometry.Point([lon, lat])\n",
        "        value = image.reduceRegion(ee.Reducer.first(), pt, scale, tileScale=8) # Added tileScale=8 here\n",
        "        return f.set({'lon': lon, 'lat': lat}).set(value)\n",
        "    fc_with_vals = fc.map(get_values)\n",
        "    features = fc_with_vals.getInfo()['features']\n",
        "    df = pd.DataFrame([f['properties'] for f in features])\n",
        "    return df\n",
        "\n",
        "def process_year(year):\n",
        "    \"\"\"处理单一年份，返回该年份各样本点的物候参数 DataFrame\"\"\"\n",
        "    start_date = f\"{year}-01-01\"\n",
        "    end_date = f\"{year}-12-31\"\n",
        "\n",
        "    print(f\"Processing {year}...\")\n",
        "\n",
        "    # 加载 HLS-S30 影像集，云掩膜，计算指数，添加 DOY\n",
        "    raw_col = (ee.ImageCollection(\"NASA/HLS/HLSS30/v002\")\n",
        "               .filterBounds(roi)\n",
        "               .filterDate(start_date, end_date)\n",
        "               .map(mask_hls_clouds)\n",
        "               .map(add_indices)\n",
        "               .map(add_doy))\n",
        "\n",
        "    # 检查是否有影像\n",
        "    size = raw_col.size().getInfo()\n",
        "    if size == 0:\n",
        "        print(f\"  No HLS data found for {year}, skipping.\")\n",
        "        return None\n",
        "\n",
        "    # 时间平滑\n",
        "    indices_list = ['NDVI', 'EVI', 'GCC', 'NDPI', 'NIRv']\n",
        "    smooth_col = temporal_smooth(raw_col, smooth_window_days, indices_list + ['DOY'],\n",
        "                                 start_date, end_date)\n",
        "\n",
        "    # 物候参数提取\n",
        "    pheno_image = extract_phenology(smooth_col, index_name)\n",
        "    pheno_image = pheno_image.rename([f\"{index_name}_{p}\" for p in ['SOS', 'POS', 'EOS', 'LOS']])\n",
        "\n",
        "    # 提取样本点值\n",
        "    df = extract_at_points(roi, pheno_image, scale=30)\n",
        "    df['year'] = year\n",
        "\n",
        "    # 转换为数值类型\n",
        "    for col in [f\"{index_name}_{p}\" for p in ['SOS', 'POS', 'EOS', 'LOS']]:\n",
        "        if col in df.columns:\n",
        "            df[col] = pd.to_numeric(df[col], errors='coerce')\n",
        "\n",
        "    print(f\"  -> {len(df)} samples processed\")\n",
        "    return df\n",
        "\n",
        "# ======================= 3. 逐年处理并汇总 =======================\n",
        "all_dfs = []\n",
        "for yr in years:\n",
        "    df_yr = process_year(yr)\n",
        "    if df_yr is not None:\n",
        "        all_dfs.append(df_yr)\n",
        "\n",
        "if len(all_dfs) == 0:\n",
        "    print(\"No data found for any year. Exiting.\")\n",
        "else:\n",
        "    df_total = pd.concat(all_dfs, ignore_index=True)\n",
        "\n",
        "    # ======================= 4. 过滤合理范围（可根据实际调整） =======================\n",
        "    sos_col = f\"{index_name}_SOS\"\n",
        "    eos_col = f\"{index_name}_EOS\"\n",
        "    pos_col = f\"{index_name}_POS\"\n",
