        "import ee\n",
        "import pandas as pd\n",
        "from tabulate import tabulate\n",
        "\n",
        "# ======================= 0. 初始化 Earth Engine =======================\n",
        "try:\n",
        "    ee.Initialize(project='ee-bqt2000204051')   # 请替换为您的项目ID\n",
        "except:\n",
        "    ee.Authenticate()\n",
        "    ee.Initialize(project='ee-bqt2000204051')\n",
        "\n",
        "# ======================= 1. 全局配置 =======================\n",
        "roi = ee.FeatureCollection(\"projects/my-project-paper-462110/assets/wuhan_samples_2024\")  # 替换为您的点集\n",
        "index_name = 'NIRv'          # 可选 'NDVI', 'EVI', 'GCC', 'NDPI', 'NIRv'\n",
        "smooth_window_days = 15      # 平滑窗口（天）\n",
        "years = list(range(2000, 2025))  # 2000–2024\n",
        "\n",
        "# 平滑参数设置\n",
        "smooth_method = 'median'            # 'median' 或 'mean'\n",
        "filter_threshold = None             # 若为均值平滑，可设置阈值（如0.35）过滤异常影像；None表示不过滤\n",
        "                                    # 注意：median平滑自动抗异常，无需此参数\n",
        "\n",
        "# ======================= 2. 辅助函数 =======================\n",
        "def mask_hls_clouds(image):\n",
        "    \"\"\"HLS-S30 云掩膜：基于 Fmask 波段\"\"\"\n",
        "    fmask = image.select('Fmask')\n",
        "    mask = fmask.bitwiseAnd(1 << 1).eq(0).And(fmask.bitwiseAnd(1 << 2).eq(0)).And(fmask.bitwiseAnd(1 << 3).eq(0))\n",
        "    return image.updateMask(mask).divide(10000).copyProperties(image, ['system:time_start'])\n",
        "\n",
        "def add_indices(image):\n",
        "    \"\"\"添加植被指数\"\"\"\n",
        "    blue = image.select('B2')\n",
        "    green = image.select('B3')\n",
        "    red = image.select('B4')\n",
        "    nir = image.select('B8')\n",
        "    swir1 = image.select('B11')\n",
        "    ndvi = image.normalizedDifference(['B8', 'B4']).rename('NDVI')\n",
        "    evi = image.expression('2.5 * ((NIR - RED) / (NIR + 6 * RED - 7.5 * BLUE + 1))',\n",
        "                           {'NIR': nir, 'RED': red, 'BLUE': blue}).rename('EVI')\n",
        "    gcc = green.divide(red.add(green).add(blue)).rename('GCC')\n",
        "    ndpi = image.normalizedDifference(['B8', 'B11']).rename('NDPI')\n",
        "    nirv = ndvi.multiply(nir).rename('NIRv')\n",
        "    return image.addBands([ndvi, evi, gcc, ndpi, nirv])\n",
        "\n",
        "def add_doy(image):\n",
        "    \"\"\"添加日序数（Day of Year, 1-366）\"\"\"\n",
        "    doy = ee.Date(image.get('system:time_start')).getRelative('day', 'year').add(1)\n",
        "    return image.addBands(ee.Image.constant(doy).rename('DOY').float())\n",
        "\n",
        "def temporal_smooth(collection, window_days, band_names, start_date, end_date,\n",
        "                    method='median', filter_thresh=None):\n",
        "    \"\"\"\n",
        "    对 ImageCollection 进行时间窗口平滑。\n",
        "    Args:\n",
        "        method: 'median' 或 'mean'\n",
        "        filter_thresh: 仅当 method='mean' 时有效，过滤与窗口均值差异 > filter_thresh 的影像\n",
        "    \"\"\"\n",
        "    start = ee.Date(start_date)\n",
        "    end = ee.Date(end_date)\n",
        "    n_intervals = end.difference(start, 'day').divide(window_days).ceil()\n",
        "    dates = ee.List.sequence(0, n_intervals.subtract(1))\n",
        "\n",
        "    def composite(n):\n",
        "        t_start = start.advance(ee.Number(n).multiply(window_days), 'day')\n",
        "        t_end = t_start.advance(window_days, 'day')\n",
        "        col_window = collection.filterDate(t_start, t_end).select(band_names)\n",
        "\n",
        "        if method == 'median':\n",
        "            # 中值平滑：自动抗异常\n",
        "            median_img = col_window.median().unmask(0).float()\n",
        "            # 空集合处理\n",
        "            median_img = ee.Image(ee.Algorithms.If(\n",
        "                col_window.size().gt(0),\n",
        "                median_img,\n",
        "                ee.Image.constant(ee.List.repeat(0, len(band_names))).rename(band_names).unmask(0).float()\n",
        "            ))\n",
        "            mid_date = t_start.advance(window_days/2, 'day')\n",
        "            doy = mid_date.getRelative('day', 'year').add(1)\n",
        "            return median_img.addBands(ee.Image.constant(doy).rename('DOY').float()).set('system:time_start', mid_date.millis())\n",
        "\n",
        "        else:  # method == 'mean' 且可选用 filter_thresh 剔除异常\n",
        "            # 先计算窗口内均值（用于过滤）\n",
        "            mean_ref = col_window.mean().unmask(0).float()\n",
        "            # 定义过滤函数：保留与均值差异 <= filter_thresh 的影像\n",
        "            def keep_if_close(img):\n",
        "                # 仅对 index_name 波段进行差异判断（可根据需要改为所有波段）\n",
        "                diff = img.select(band_names[0]).subtract(mean_ref.select(band_names[0])).abs()\n",
        "                mask = diff.lte(filter_thresh) if filter_thresh is not None else ee.Image(1)\n",
        "                return img.updateMask(mask)\n",
        "            filtered = col_window.map(keep_if_close).filter(ee.Filter.notNull(band_names))\n",
        "            # 计算最终均值\n",
        "            mean_final = filtered.mean().unmask(0).float()\n",
        "            mean_final = ee.Image(ee.Algorithms.If(\n",
        "                filtered.size().gt(0),\n",
        "                mean_final,\n",
        "                ee.Image.constant(ee.List.repeat(0, len(band_names))).rename(band_names).unmask(0).float()\n",
        "            ))\n",
        "            mid_date = t_start.advance(window_days/2, 'day')\n",
        "            doy = mid_date.getRelative('day', 'year').add(1)\n",
        "            return mean_final.addBands(ee.Image.constant(doy).rename('DOY').float()).set('system:time_start', mid_date.millis())\n",
        "\n",
        "    return ee.ImageCollection.fromImages(dates.map(composite))\n",
        "\n",
        "def extract_phenology(smoothed_col, idx):\n",
        "    \"\"\"\n",
        "    基于平滑后的影像集合提取物候参数\n",
        "    返回一个包含 SOS, POS, EOS, LOS 的 Image\n",
        "    \"\"\"\n",
        "    # 全年指数最大值、最小值\n",
        "    index_max = smoothed_col.select(idx).reduce(ee.Reducer.max())\n",
        "    index_min = smoothed_col.select(idx).reduce(ee.Reducer.min())\n",
        "\n",
        "    # 阈值：振幅的 20%（可根据研究调整）\n",
        "    threshold = index_min.add(index_max.subtract(index_min).multiply(0.2))\n",
        "\n",
        "    # 峰值日期（质量合成）\n",
        "    pos_raw = smoothed_col.qualityMosaic(idx).select('DOY')\n",
        "    pos_doy = ee.Image(ee.Algorithms.If(\n",
        "        pos_raw.bandNames().size().gt(0),\n",
        "        pos_raw.rename('POS'),\n",
        "        ee.Image.constant(0).divide(0).rename('POS')\n",
        "    ))\n",
        "\n",
        "    # SOS：峰值前首次超过阈值的 DOY\n",
        "    def get_sos(img):\n",
        "        cond = img.select(idx).gt(threshold).And(img.select('DOY').lt(pos_doy))\n",
        "        return img.select('DOY').updateMask(cond)\n",
        "    sos_reduced = smoothed_col.map(get_sos).reduce(ee.Reducer.min())\n",
        "    sos_doy = ee.Image(ee.Algorithms.If(\n",
        "        sos_reduced.bandNames().size().gt(0),\n",
        "        sos_reduced.rename('SOS'),\n",
        "        ee.Image.constant(0).divide(0).rename('SOS')\n",
        "    ))\n",
        "\n",
        "    # EOS：峰值后最后一次超过阈值的 DOY\n",
        "    def get_eos(img):\n",
        "        cond = img.select(idx).gt(threshold).And(img.select('DOY').gt(pos_doy))\n",
        "        return img.select('DOY').updateMask(cond)\n",
        "    eos_reduced = smoothed_col.map(get_eos).reduce(ee.Reducer.max())\n",
        "    eos_doy = ee.Image(ee.Algorithms.If(\n",
        "        eos_reduced.bandNames().size().gt(0),\n",
        "        eos_reduced.rename('EOS'),\n",
        "        ee.Image.constant(0).divide(0).rename('EOS')\n",
        "    ))\n",
        "\n",
        "    # 生长季长度\n",
        "    los = eos_doy.subtract(sos_doy).rename('LOS')\n",
        "\n",
        "    return ee.Image.cat([sos_doy, pos_doy, eos_doy, los])\n",
        "\n",
        "def extract_at_points(fc, image, scale=30):\n",
        "    \"\"\"提取每个样本点在指定影像上的值，返回 Pandas DataFrame\"\"\"\n",
        "    def get_values(f):\n",
        "        geom = f.geometry()\n",
        "        coords = geom.coordinates()\n",
        "        lon = coords.get(0)\n",
        "        lat = coords.get(1)\n",
        "        pt = ee.Geometry.Point([lon, lat])\n",
        "        value = image.reduceRegion(ee.Reducer.first(), pt, scale, tileScale=8)\n",
        "        return f.set({'lon': lon, 'lat': lat}).set(value)\n",
        "    fc_with_vals = fc.map(get_values)\n",
        "    features = fc_with_vals.getInfo()['features']\n",
        "    df = pd.DataFrame([f['properties'] for f in features])\n",
        "    return df\n",
        "\n",
        "def process_year(year):\n",
        "    \"\"\"处理单一年份，返回该年份各样本点的物候参数 DataFrame\"\"\"\n",
        "    start_date = f\"{year}-01-01\"\n",
        "    end_date = f\"{year}-12-31\"\n",
        "\n",
        "    print(f\"Processing {year}...\")\n",
        "\n",
        "    # 加载 HLS-S30 影像集，云掩膜，计算指数，添加 DOY\n",
        "    raw_col = (ee.ImageCollection(\"NASA/HLS/HLSS30/v002\")\n",
        "               .filterBounds(roi)\n",
        "               .filterDate(start_date, end_date)\n",
        "               .map(mask_hls_clouds)\n",
        "               .map(add_indices)\n",
        "               .map(add_doy))\n",
        "\n",
        "    # 检查是否有影像\n",
        "    size = raw_col.size().getInfo()\n",
        "    if size == 0:\n",
        "        print(f\"  No HLS data found for {year}, skipping.\")\n",
        "        return None\n",
        "\n",
        "    # 时间平滑\n",
        "    indices_list = ['NDVI', 'EVI', 'GCC', 'NDPI', 'NIRv']\n",
        "    smooth_col = temporal_smooth(\n",
        "        raw_col,\n",
        "        smooth_window_days,\n",
        "        indices_list + ['DOY'],\n",
        "        start_date,\n",
        "        end_date,\n",
        "        method=smooth_method,\n",
        "        filter_thresh=filter_threshold\n",
        "    )\n",
        "\n",
        "    # 物候参数提取\n",
        "    pheno_image = extract_phenology(smooth_col, index_name)\n",
        "    pheno_image = pheno_image.rename([f\"{index_name}_{p}\" for p in ['SOS', 'POS', 'EOS', 'LOS']])\n",
        "\n",
        "    # 提取样本点值\n",
        "    df = extract_at_points(roi, pheno_image, scale=30)\n",
        "    df['year'] = year\n",
        "\n",
        "    # 转换为数值类型\n",
        "    for col in [f\"{index_name}_{p}\" for p in ['SOS', 'POS', 'EOS', 'LOS']]:\n",
        "        if col in df.columns:\n",
        "            df[col] = pd.to_numeric(df[col], errors='coerce')\n",
        "\n",
        "    print(f\"  -> {len(df)} samples processed\")\n",
        "    return df\n",
        "\n",
        "# ======================= 3. 逐年处理并汇总 =======================\n",
        "all_dfs = []\n",
        "for yr in years:\n",
        "    df_yr = process_year(yr)\n",
        "    if df_yr is not None:\n",
        "        all_dfs.append(df_yr)\n",
        "\n",
        "if len(all_dfs) == 0:\n",
        "    print(\"No data found for any year. Exiting.\")\n",
        "else:\n",
        "    df_total = pd.concat(all_dfs, ignore_index=True)\n",
        "\n",
        "    # ======================= 4. 过滤合理范围 =======================\n",
        "    sos_col = f\"{index_name}_SOS\"\n",
        "    eos_col = f\"{index_name}_EOS\"\n",
        "    pos_col = f\"{index_name}_POS\"\n",
        "    los_col = f\"{index_name}_LOS\"\n",
        "\n",
        "    valid_mask = (df_total[sos_col] >= 1) & (df_total[sos_col] <= 366) & \\\n",
        "                 (df_total[eos_col] >= 1) & (df_total[eos_col] <= 366) & \\\n",
        "                 (df_total[pos_col] >= 1) & (df_total[pos_col] <= 366)\n",
        "    df_valid = df_total[valid_mask].copy()\n",
        "\n",
        "    # ======================= 5. 输出结果 =======================\n",
        "    df_valid.sort_values(['year', 'lat', 'lon'], inplace=True)\n",
        "    df_valid.reset_index(drop=True, inplace=True)\n",
        "\n",
        "    df_valid.to_csv('phenology_HLS_2000_2024.csv', index=False)\n",
        "    df_valid.to_excel('phenology_HLS_2000_2024.xlsx', index=False, engine='openpyxl')\n",
        "\n",
        "    print(\"\\n========== HLS-S30 物候参数结果 (有效年份) ==========\")\n",
        "    print(tabulate(df_valid.head(20), headers='keys', tablefmt='grid', showindex=False))\n",
        "    print(f\"\\n总有效记录数: {len(df_valid)}\")\n",
        "    print(\"结果已保存至 phenology_HLS_2000_2024.csv 和 phenology_HLS_2000_2024.xlsx\")\n",
        "\n",
        "    # 各年份平均物候统计\n",
        "    stats = df_valid.groupby('year')[[sos_col, pos_col, eos_col, los_col]].mean().round(1)\n",
        "    stats.to_excel('phenology_HLS_yearly_stats.xlsx')\n",
        "    print(\"\\n各年份平均物候参数:\")\n",
        "    print(stats)"
