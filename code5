        "import ee\n",
        "import pandas as pd\n",
        "from tabulate import tabulate\n",
        "\n",
        "# ======================= 0. 初始化 Earth Engine =======================\n",
        "try:\n",
        "    ee.Initialize(project=\"ee-bqt2000204051\")\n",
        "except:\n",
        "    ee.Authenticate()\n",
        "    ee.Initialize(project=\"ee-bqt2000204051\")\n",
        "\n",
        "# ======================= 1. 全局配置 =======================\n",
        "roi = ee.FeatureCollection(\"projects/my-project-paper-462110/assets/wuhan_samples_2024\")  # 样本点集合\n",
        "index_name = \"NIRv\"          # 可选 'NDVI', 'EVI', 'GCC', 'NIRv'\n",
        "smooth_window_days = 15      # 平滑窗口（天）\n",
        "years = list(range(1990, 2013))  # Landsat 5 TM 数据覆盖 1990–2012\n",
        "\n",
        "# ======================= 2. 辅助函数 =======================\n",
        "def mask_l5_clouds(image):\n",
        "    \"\"\"Landsat 5 TM 云掩膜：基于 QA_PIXEL 波段\"\"\"\n",
        "    qa = image.select(\"QA_PIXEL\")\n",
        "    # bit3: cloud, bit4: cloud shadow, bit5: snow/ice (0=clear)\n",
        "    mask = qa.bitwiseAnd(1 << 3).eq(0).And(qa.bitwiseAnd(1 << 4).eq(0)).And(qa.bitwiseAnd(1 << 5).eq(0))\n",
        "    # 反射率缩放：Collection 2 统一使用 0.0000275 和 -0.2\n",
        "    scaled = image.select([\"SR_B1\", \"SR_B2\", \"SR_B3\", \"SR_B4\", \"SR_B5\"]) \\\n",
        "                  .multiply(0.0000275).add(-0.2).rename([\"B2\", \"B3\", \"B4\", \"B5\", \"B6\"])\n",
        "    return image.addBands(scaled, overwrite=True).updateMask(mask).copyProperties(image, [\"system:time_start\"])\n",
        "\n",
        "def add_indices(image):\n",
        "    \"\"\"添加植被指数（波段名 B2:蓝, B3:绿, B4:红, B5:近红外, B6:短波红外）\"\"\"\n",
        "    blue = image.select(\"B2\")\n",
        "    green = image.select(\"B3\")\n",
        "    red = image.select(\"B4\")\n",
        "    nir = image.select(\"B5\")\n",
        "    swir1 = image.select(\"B6\")       # Landsat 5 SR_B5 对应短波红外\n",
        "    ndvi = image.normalizedDifference([\"B5\", \"B4\"]).rename(\"NDVI\")\n",
        "    evi = image.expression(\"2.5 * ((NIR - RED) / (NIR + 6 * RED - 7.5 * BLUE + 1))\",\n",
        "                           {\"NIR\": nir, \"RED\": red, \"BLUE\": blue}).rename(\"EVI\")\n",
        "    gcc = green.divide(red.add(green).add(blue)).rename(\"GCC\")\n",
        "    ndpi = image.normalizedDifference([\"B5\", \"B6\"]).rename(\"NDPI\")\n",
        "    nirv = ndvi.multiply(nir).rename(\"NIRv\")\n",
        "    return image.addBands([ndvi, evi, gcc, ndpi, nirv])\n",
        "\n",
        "def temporal_smooth(collection, window_days, band_names, start_date, end_date):\n",
        "    \"\"\"对 ImageCollection 进行时间窗口平均平滑，返回新的 ImageCollection\"\"\"\n",
        "    start = ee.Date(start_date)\n",
        "    end = ee.Date(end_date)\n",
        "    n_intervals = end.difference(start, \"day\").divide(window_days).ceil()\n",
        "    dates = ee.List.sequence(0, n_intervals.subtract(1))\n",
        "    def composite(n):\n",
        "        t_start = start.advance(ee.Number(n).multiply(window_days), \"day\")\n",
        "        t_end = t_start.advance(window_days, \"day\")\n",
        "        col_window = collection.filterDate(t_start, t_end).select(band_names)\n",
        "\n",
        "        # 创建零值浮点影像（确保数据类型一致）\n",
        "        zero_bands_float = ee.Image.constant(ee.List.repeat(0, len(band_names))).rename(band_names).unmask(0).float()\n",
        "        mean_img_float = col_window.mean().unmask(0).float()\n",
        "        mean_img_with_float_bands = ee.Image(ee.Algorithms.If(\n",
        "            col_window.size().gt(0),\n",
        "            mean_img_float,\n",
        "            zero_bands_float\n",
        "        ))\n",
        "\n",
        "        mid_date = t_start.advance(window_days/2, \"day\")\n",
        "        doy = mid_date.getRelative(\"day\", \"year\").add(1)\n",
        "        doy_img = ee.Image.constant(doy).rename(\"DOY\").float()\n",
        "\n",
        "        return mean_img_with_float_bands.addBands(doy_img).set(\"system:time_start\", mid_date.millis())\n",
        "    return ee.ImageCollection.fromImages(dates.map(composite))\n",
        "\n",
        "def extract_phenology(smoothed_col, idx):\n",
        "    \"\"\"基于平滑后的影像集合提取物候参数（SOS, POS, EOS, LOS）\"\"\"\n",
        "    index_max = smoothed_col.select(idx).reduce(ee.Reducer.max())\n",
        "    index_min = smoothed_col.select(idx).reduce(ee.Reducer.min())\n",
        "    threshold = index_min.add(index_max.subtract(index_min).multiply(0.3))  # 30% 振幅阈值\n",
        "\n",
        "    pos_doy = smoothed_col.qualityMosaic(idx).select(\"DOY\").rename(\"POS\")\n",
        "\n",
        "    def get_sos(img):\n",
        "        cond = img.select(idx).gt(threshold).And(img.select(\"DOY\").lt(pos_doy))\n",
        "        return img.select(\"DOY\").updateMask(cond)\n",
        "    sos_doy = smoothed_col.map(get_sos).reduce(ee.Reducer.min()).rename(\"SOS\")\n",
        "\n",
        "    def get_eos(img):\n",
        "        cond = img.select(idx).gt(threshold).And(img.select(\"DOY\").gt(pos_doy))\n",
        "        return img.select(\"DOY\").updateMask(cond)\n",
        "    eos_doy = smoothed_col.map(get_eos).reduce(ee.Reducer.max()).rename(\"EOS\")\n",
        "\n",
        "    los = eos_doy.subtract(sos_doy).rename(\"LOS\")\n",
        "    return ee.Image.cat([sos_doy, pos_doy, eos_doy, los])\n",
        "\n",
        "def process_year(year):\n",
        "    \"\"\"处理单一年份，返回该年份各样本点的物候参数 DataFrame\"\"\"\n",
        "    start_date = f\"{year}-01-01\"\n",
        "    end_date = f\"{year}-12-31\"\n",
        "\n",
        "    # 加载 Landsat 5 TM 影像集，云掩膜，计算指数\n",
        "    raw_col = (ee.ImageCollection(\"LANDSAT/LT05/C02/T1_L2\")\n",
        "               .filterBounds(roi)\n",
        "               .filterDate(start_date, end_date)\n",
        "               .filter(ee.Filter.lt(\"CLOUD_COVER\", 20))\n",
        "               .map(mask_l5_clouds)\n",
        "               .map(add_indices))\n",
        "\n",
        "    # 时间平滑\n",
        "    smooth_col = temporal_smooth(raw_col, smooth_window_days,\n",
        "                                 [\"NDVI\", \"EVI\", \"GCC\", \"NDPI\", \"NIRv\"],\n",
        "                                 start_date, end_date)\n",
        "\n",
        "    # 提取物候参数\n",
        "    pheno_raw = extract_phenology(smooth_col, index_name)\n",
        "    pheno_image = pheno_raw.rename([f\"{index_name}_{p}\" for p in [\"SOS\", \"POS\", \"EOS\", \"LOS\"]])\n",
        "\n",
        "    # 在样本点上提取数值\n",
        "    def extract_at_points(f):\n",
        "        geom = f.geometry()\n",
        "        vals = pheno_image.reduceRegion(reducer=ee.Reducer.first(), geometry=geom,\n",
        "                                        scale=30, bestEffort=True, tileScale=8)\n",
        "        return f.set(vals).set({\"lon\": geom.coordinates().get(0), \"lat\": geom.coordinates().get(1)})\n",
        "\n",
        "    results_fc = roi.map(extract_at_points)\n",
        "    features = results_fc.getInfo()[\"features\"]\n",
        "\n",
        "    rows = []\n",
        "    for f in features:\n",
        "        props = f[\"properties\"]\n",
        "        row = {\n",
        "            \"year\": year,\n",
        "            \"lon\": props.get(\"lon\"),\n",
        "            \"lat\": props.get(\"lat\"),\n",
        "            f\"{index_name}_SOS\": props.get(f\"{index_name}_SOS\"),\n",
        "            f\"{index_name}_POS\": props.get(f\"{index_name}_POS\"),\n",
        "            f\"{index_name}_EOS\": props.get(f\"{index_name}_EOS\"),\n",
        "            f\"{index_name}_LOS\": props.get(f\"{index_name}_LOS\")\n",
        "        }\n",
        "        rows.append(row)\n",
        "\n",
        "    df_year = pd.DataFrame(rows)\n",
        "    # 转换为数值类型\n",
        "    for col in [f\"{index_name}_{p}\" for p in [\"SOS\", \"POS\", \"EOS\", \"LOS\"]]:\n",
        "        df_year[col] = pd.to_numeric(df_year[col], errors=\"coerce\")\n",
        "    return df_year\n",
        "\n",
        "# ======================= 3. 逐年处理并汇总 =======================\n",
        "all_dfs = []\n",
        "for yr in years:\n",
        "    print(f\"Processing {yr}...\")\n",
        "    df_yr = process_year(yr)\n",
        "    all_dfs.append(df_yr)\n",
        "    print(f\"  -> {len(df_yr)} samples\")\n",
        "\n",
        "df_total = pd.concat(all_dfs, ignore_index=True)\n",
        "\n",
        "# ======================= 4. 过滤合理范围（可根据实际调整） =======================\n",
        "sos_col = f\"{index_name}_SOS\"\n",
        "eos_col = f\"{index_name}_EOS\"\n",
        "pos_col = f\"{index_name}_POS\"\n",
        "los_col = f\"{index_name}_LOS\"\n",
        "\n",
        "valid_mask = (df_total[sos_col] >= 60) & (df_total[sos_col] <= 366) & \\\n",
        "             (df_total[eos_col] >= 50) & (df_total[eos_col] <= 340) & \\\n",
        "             (df_total[pos_col] >= 1) & (df_total[pos_col] <= 366)\n",
        "df_valid = df_total[valid_mask].copy()\n",
        "\n",
        "# ======================= 5. 输出结果 =======================\n",
        "df_valid.sort_values([\"year\", \"lat\", \"lon\"], inplace=True)\n",
        "df_valid.reset_index(drop=True, inplace=True)\n",
        "\n",
        "df_valid.to_excel(\"phenology_Landsat5_1990_2012.xlsx\", index=False, engine=\"openpyxl\")\n",
        "df_valid.to_csv(\"phenology_Landsat5_1990_2012.csv\", index=False)\n",
        "\n",
        "print(\"\\n========== Landsat 5 TM 物候参数结果 (1990–2012) ==========\")\n",
        "print(tabulate(df_valid.head(20), headers=\"keys\", tablefmt=\"grid\", showindex=False))\n",
        "print(f\"\\n总有效记录数: {len(df_valid)}\")\n",
        "print(\"结果已保存至 phenology_Landsat5_1990_2012.xlsx 和 phenology_Landsat5_1990_2012.csv\")\n",
        "\n",
        "# 可选：输出各年份平均物候统计\n",
        "stats = df_valid.groupby(\"year\")[[sos_col, pos_col, eos_col, los_col]].mean().round(1)\n",
        "stats.to_excel(\"phenology_Landsat5_yearly_stats.xlsx\")\n",
        "print(\"\\n各年份平均物候参数:\")\n",
        "print(stats)"
      ],
