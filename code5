        "    # 2. Determine POS using qualityMosaic\n",
        "    pos_raw = smoothed_col.qualityMosaic(idx).select('DOY')\n",
        "    pos_doy = ee.Image(ee.Algorithms.If(\n",
        "        pos_raw.bandNames().size().gt(0),\n",
        "        pos_raw.rename('POS'),\n",
        "        ee.Image.constant(0).divide(0).rename('POS')\n",
        "    ))\n",
        "\n",
        "    # 3. Logic for SOS and EOS\n",
        "    # SOS: first DOY before peak where NDPI > threshold\n",
        "    def get_sos(img):\n",
        "        cond = img.select(idx).gt(threshold).And(img.select('DOY').lt(pos_doy))\n",
