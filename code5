        "def extract_phenology(smoothed_col, idx):\n",
        "    # 1. Calculate annual max and min\n",
        "    index_max = smoothed_col.select(idx).reduce(ee.Reducer.max())\n",
        "    index_min = smoothed_col.select(idx).reduce(ee.Reducer.min())\n",
        "\n",
        "    # 2. Define 20% threshold\n",
        "    threshold = index_min.add(index_max.subtract(index_min).multiply(0.35))\n",
        "\n",
        "    # 3. Determine POS using qualityMosaic\n",
        "    pos_doy = smoothed_col.qualityMosaic(idx).select('DOY').rename('POS')\n",
        "\n",
        "    # 4. Calculate SOS (Min DOY before POS above threshold)\n",
        "    def get_sos(img):\n",
        "        before_peak = img.select('DOY').updateMask(\n",
        "            img.select(idx).gt(threshold).And(img.select('DOY').lt(pos_doy))\n",
        "        )\n",
        "        return before_peak\n",
        "    sos_doy = smoothed_col.map(get_sos).reduce(ee.Reducer.min()).rename('SOS')\n",
        "\n",
        "    # 5. Calculate EOS (Max DOY after POS above threshold)\n",
        "    def get_eos(img):\n",
        "        after_peak = img.select('DOY').updateMask(\n",
        "            img.select(idx).gt(threshold).And(img.select('DOY').gt(pos_doy))\n",
        "        )\n",
        "        return after_peak\n",
        "    eos_doy = smoothed_col.map(get_eos).reduce(ee.Reducer.max()).rename('EOS')\n",
        "\n",
        "    # 6. Calculate LOS\n",
        "    los = eos_doy.subtract(sos_doy).rename('LOS')\n",
        "\n",
        "    # 7. Concatenate into 4-band image\n",
        "    return ee.Image.cat([sos_doy, pos_doy, eos_doy, los])\n",
        "\n",
        "# Apply extraction to the smoothed collection (using NDPI)\n",
        "pheno_image_hls = extract_phenology(smooth_col, 'NDPI')\n",
        "\n",
        "# 8. Point-based extraction at 30m resolution\n",
        "def extract_at_points(f):\n",
        "    geom = f.geometry()\n",
        "    vals = pheno_image_hls.reduceRegion(\n",
        "        reducer=ee.Reducer.first(),\n",
        "        geometry=geom,\n",
        "        scale=30,\n",
        "        bestEffort=True\n",
        "    )\n",
        "    return f.set(vals).set({'lon': geom.coordinates().get(0), 'lat': geom.coordinates().get(1)})\n",
        "\n",
