      "cell_type": "code",
      "source": [
        "import ee\n",
        "import pandas as pd\n",
        "from tabulate import tabulate\n",
        "\n",
        "# ======================= 0. 初始化 Earth Engine =======================\n",
        "try:\n",
        "    ee.Initialize(project='ee-bqt2000204051')\n",
        "except:\n",
        "    ee.Authenticate()\n",
        "    ee.Initialize(project='ee-bqt2000204051')\n",
        "\n",
        "# ======================= 1. 全局配置 =======================\n",
        "roi = ee.FeatureCollection(\"projects/my-project-paper-462110/assets/wuhan_samples_2024\")  # 样本点集合\n",
        "index_name = 'NIRv'          # 可选 'NDVI', 'EVI', 'GCC', 'NDPI', 'NIRv'\n",
        "smooth_window_days = 15      # 平滑窗口（天）\n",
        "years = list(range(2000, 2025))  # 2000–2024\n",
        "\n",
        "# ======================= 2. 辅助函数 =======================\n",
        "def mask_s2_clouds(image):\n",
        "    \"\"\"Sentinel-2 云掩膜（基于 SCL）\"\"\"\n",
        "    scl = image.select('SCL')\n",
        "    mask = scl.neq(3).And(scl.neq(8)).And(scl.neq(9)).And(scl.neq(10))\n",
        "    return image.updateMask(mask).divide(10000).copyProperties(image, ['system:time_start'])\n",
        "\n",
        "def add_indices(image):\n",
        "    \"\"\"添加植被指数\"\"\"\n",
        "    blue = image.select('B2')\n",
        "    green = image.select('B3')\n",
        "    red = image.select('B4')\n",
        "    nir = image.select('B8')\n",
        "    swir1 = image.select('B11')\n",
        "    ndvi = image.normalizedDifference(['B8', 'B4']).rename('NDVI')\n",
        "    evi = image.expression('2.5 * ((NIR - RED) / (NIR + 6 * RED - 7.5 * BLUE + 1))',\n",
        "                           {'NIR': nir, 'RED': red, 'BLUE': blue}).rename('EVI')\n",
        "    gcc = green.divide(red.add(green).add(blue)).rename('GCC')\n",
        "    ndpi = image.normalizedDifference(['B8', 'B11']).rename('NDPI')\n",
        "    nirv = ndvi.multiply(nir).rename('NIRv')\n",
        "    return image.addBands([ndvi, evi, gcc, ndpi, nirv])\n",
        "\n",
        "def add_doy(image):\n",
        "    \"\"\"添加日序数（Day of Year, 1-366）\"\"\"\n",
        "    doy = ee.Date(image.get('system:time_start')).getRelative('day', 'year').add(1)\n",
        "    return image.addBands(ee.Image.constant(doy).rename('DOY').float())\n",
        "\n",
        "def temporal_smooth(collection, window_days, band_names, start_date, end_date):\n",
        "    \"\"\"\n",
        "    对 ImageCollection 进行时间窗口平均平滑\n",
        "    返回一个新的 ImageCollection，每个影像代表窗口内的均值\n",
        "    \"\"\"\n",
        "    start = ee.Date(start_date)\n",
        "    end = ee.Date(end_date)\n",
        "    n_intervals = end.difference(start, 'day').divide(window_days).ceil()\n",
        "    dates = ee.List.sequence(0, n_intervals.subtract(1))\n",
        "    def composite(n):\n",
        "        t_start = start.advance(ee.Number(n).multiply(window_days), 'day')\n",
        "        t_end = t_start.advance(window_days, 'day')\n",
        "        col_window = collection.filterDate(t_start, t_end).select(band_names)\n",
        "\n",
        "        # Create a zero image with float bands\n",
        "        zero_bands = ee.Image.constant(ee.List.repeat(0, len(band_names))).rename(band_names).float()\n",
        "\n",
        "        # Calculate mean image, ensuring all bands are float\n",
        "        mean_img_with_float_bands = ee.Image(ee.Algorithms.If(\n",
        "            col_window.size().gt(0),\n",
        "            col_window.mean().float(),  # Explicitly cast to float\n",
        "            zero_bands\n",
        "        ))\n",
        "\n",
        "        # 使用窗口中间日期作为时间戳\n",
        "        mid_date = t_start.advance(window_days/2, 'day')\n",
        "        doy = mid_date.getRelative('day', 'year').add(1)\n",
        "        doy_img = ee.Image.constant(doy).rename('DOY').float()\n",
        "\n",
        "        return mean_img_with_float_bands.addBands(doy_img).set('system:time_start', mid_date.millis())\n",
        "    return ee.ImageCollection.fromImages(dates.map(composite))\n",
        "\n",
        "def extract_phenology(smoothed_col, index_name):\n",
        "    \"\"\"\n",
        "    基于平滑后的影像集合提取物候参数\n",
        "    返回一个包含 SOS, POS, EOS, LOS 的 Image\n",
        "    \"\"\"\n",
        "    # 全年的指数最大值、最小值\n",
        "    index_max = smoothed_col.select(index_name).reduce(ee.Reducer.max())\n",
        "    index_min = smoothed_col.select(index_name).reduce(ee.Reducer.min())\n",
        "    # 阈值：最大最小值区间的 20%\n",
        "    threshold = index_min.add(index_max.subtract(index_min).multiply(0.2))\n",
        "    # 峰值日期（质量合成）\n",
        "    pos_doy = smoothed_col.qualityMosaic(index_name).select('DOY').rename('POS')\n",
        "    # SOS：峰值前首次超过阈值\n",
        "    def get_sos(img):\n",
        "        before_peak = img.select('DOY').updateMask(img.select(index_name).gt(threshold)) \\\n",
        "                        .updateMask(img.select('DOY').lt(pos_doy))\n",
        "        return before_peak\n",
        "    sos_doy = smoothed_col.map(get_sos).reduce(ee.Reducer.min()).rename('SOS')\n",
        "    # EOS：峰值后最后一次超过阈值\n",
        "    def get_eos(img):\n",
        "        after_peak = img.select('DOY').updateMask(img.select(index_name).gt(threshold)) \\\n",
        "                       .updateMask(img.select('DOY').gt(pos_doy))\n",
        "        return after_peak\n",
        "    eos_doy = smoothed_col.map(get_eos).reduce(ee.Reducer.max()).rename('EOS')\n",
        "    # 生长季长度\n",
        "    los = eos_doy.subtract(sos_doy).rename('LOS')\n",
        "    return ee.Image.cat([sos_doy, pos_doy, eos_doy, los])\n",
        "\n",
        "def extract_values_at_points(fc, image, band_names):\n",
        "    \"\"\"提取每个样本点在指定影像上的值，返回 Pandas DataFrame，包含坐标\"\"\"\n",
        "    def get_values(f):\n",
        "        geom = f.geometry()\n",
        "        coords = geom.coordinates()\n",
        "        lon = coords.get(0)\n",
        "        lat = coords.get(1)\n",
        "        pt = ee.Geometry.Point([lon, lat])\n",
        "        value = image.reduceRegion(ee.Reducer.first(), pt, 10)\n",
        "        return f.set({'lon': lon, 'lat': lat}).set(value)\n",
        "    fc_with_vals = fc.map(get_values)\n",
        "    props = ee.List(band_names).cat(['system:index', 'lon', 'lat'])\n",
        "    data = fc_with_vals.select(props).getInfo()['features']\n",
        "    df = pd.DataFrame([f['properties'] for f in data])\n",
        "    return df\n",
        "\n",
        "def process_year(year):\n",
        "    \"\"\"处理单一年份，返回该年份各样本点的物候参数 DataFrame\"\"\"\n",
        "    start_date = f\"{year}-01-01\"\n",
        "    end_date = f\"{year}-12-31\"\n",
        "\n",
        "    # Sentinel-2 数据始于 2015 年，早于该年份则跳过\n",
        "    if year < 2015:\n",
        "        print(f\"  Warning: Sentinel-2 data not available for {year}, skipping.\")\n",
        "        return None\n",
        "\n",
        "    print(f\"Processing {year}...\")\n",
        "\n",
        "    # 加载原始影像（云量<20%，云掩膜）\n",
        "    raw_col = (ee.ImageCollection('COPERNICUS/S2_SR_HARMONIZED')\n",
        "               .filterBounds(roi)\n",
        "               .filterDate(start_date, end_date)\n",
        "               .filter(ee.Filter.lt('CLOUDY_PIXEL_PERCENTAGE', 20))\n",
        "               .map(mask_s2_clouds)\n",
        "               .map(add_indices)\n",
        "               .map(add_doy))\n",
        "\n",
        "    # 提取需要的指数波段\n",
        "    indices_list = ['NDVI', 'EVI', 'GCC', 'NDPI', 'NIRv']\n",
        "    # 平滑处理\n",
        "    smooth_col = temporal_smooth(raw_col, smooth_window_days, indices_list + ['DOY'],\n",
        "                                 start_date, end_date)\n",
        "\n",
        "    # 物候参数提取\n",
        "    pheno_image = extract_phenology(smooth_col, index_name)\n",
        "    pheno_image = pheno_image.rename([f\"{index_name}_{p}\" for p in ['SOS', 'POS', 'EOS', 'LOS']])\n",
        "\n",
        "    # 提取样本点值\n",
        "    band_names = pheno_image.bandNames().getInfo()\n",
        "    df = extract_values_at_points(roi, pheno_image, band_names)\n",
        "\n",
        "    # 添加年份列\n",
        "    df['year'] = year\n",
        "\n",
        "    # 转换为数值类型\n",
        "    for col in [f\"{index_name}_{p}\" for p in ['SOS', 'POS', 'EOS', 'LOS']]:\n",
        "        if col in df.columns:\n",
        "            df[col] = pd.to_numeric(df[col], errors='coerce')\n",
        "\n",
        "    print(f\"  -> {len(df)} samples\")\n",
        "    return df\n",
        "\n",
        "# ======================= 3. 逐年处理并汇总 =======================\n",
        "all_dfs = []\n",
        "for yr in years:\n",
        "    df_yr = process_year(yr)\n",
        "    if df_yr is not None:\n",
        "        all_dfs.append(df_yr)\n",
        "\n",
        "df_total = pd.concat(all_dfs, ignore_index=True)\n",
        "\n",
        "# ======================= 4. 过滤合理范围（根据实际需求可调整） =======================\n",
        "sos_col = f\"{index_name}_SOS\"\n",
        "eos_col = f\"{index_name}_EOS\"\n",
        "pos_col = f\"{index_name}_POS\"\n",
