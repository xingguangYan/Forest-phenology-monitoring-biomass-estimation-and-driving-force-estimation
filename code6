    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.cm as cm\n",
    "\n",
    "# 读取CSV文件\n",
    "df = pd.read_csv(r'D:\\2025论文\\变量重要性图.csv')\n",
    "\n",
    "# 假设CSV有两列：'变量' 和 '重要性'\n",
    "variables = df['Feature']\n",
    "importances = df['Normalized Value']\n",
    "\n",
    "# 计算螺旋参数\n",
    "theta = np.linspace(0, 4 * np.pi, len(variables))\n",
    "r = np.linspace(1, 10, len(variables))\n",
    "\n",
    "# 颜色映射\n",
    "colors = cm.viridis(np.linspace(0, 1, len(variables)))\n",
    "\n",
    "fig = plt.figure(figsize=(8, 8))\n",
    "ax = fig.add_subplot(111, polar=True)\n",
    "\n",
    "# 绘制螺旋点\n",
    "for i in range(len(variables)):\n",
    "    ax.scatter(theta[i], r[i], s=importances[i]*300, color=colors[i], label=variables[i], alpha=0.8, edgecolors='k')\n",
    "\n",
    "# 添加变量标签\n",
    "for i in range(len(variables)):\n",
    "    ax.text(theta[i], r[i]+0.5, variables[i], fontsize=10, ha='center', va='center', color=colors[i])\n",
    "\n",
    "ax.set_title('变量重要性螺旋图', fontsize=16)\n",
    "ax.set_yticklabels([])\n",
    "ax.set_xticklabels([])\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# 极坐标柱状图，每个feature为一个柱状，显示其数值，无底盘\n",
    "fig2, ax2 = plt.subplots(figsize=(10, 10), subplot_kw={'projection': 'polar'})\n",
    "\n",
    "# 柱状宽度\n",
    "width = 2 * np.pi / len(variables)\n",
    "\n",
    "# 角度位置\n",
    "angles = np.linspace(0, 2 * np.pi, len(variables), endpoint=False)\n",
    "\n",
    "# 绘制柱状\n",
    "bars = ax2.bar(angles, importances, width=width*0.9, color=colors, alpha=0.9, edgecolor='k')\n",
    "\n",
    "# 添加feature标签和数值\n",
    "for angle, bar, label, value in zip(angles, bars, variables, importances):\n",
    "    # 标签\n",
    "    ax2.text(angle, bar.get_height() + 0.05, f\"{label}\\n{value:.2f}\", \n",
    "             ha='center', va='bottom', fontsize=10, rotation=np.degrees(angle),\n",
    "             rotation_mode='anchor')\n",
    "\n",
    "# 美化\n",
    "ax2.set_yticklabels([])\n",
    "ax2.set_xticklabels([])\n",
    "ax2.set_title('feature importance', fontsize=16)\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# 只绘制螺旋散点图，去除极坐标柱状图和数值，仅保留feature名称，刻度以图例显示\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(8, 8), subplot_kw={'projection': 'polar'})\n",
    "\n",
    "# 绘制螺旋点\n",
    "for i in range(len(variables)):\n",
    "    ax.scatter(theta[i], r[i], s=importances[i]*300, color=colors[i], label=variables[i], alpha=0.8, edgecolors='k')\n",
    "\n",
    "# 添加变量标签\n",
    "for i in range(len(variables)):\n",
    "    ax.text(theta[i], r[i]+0.5, variables[i], fontsize=10, ha='center', va='center', color=colors[i])\n",
    "\n",
    "# 去除坐标轴刻度\n",
    "ax.set_yticklabels([])\n",
    "ax.set_xticklabels([])\n",
    "\n",
    "# 图例显示feature名称\n",
    "handles, labels = ax.get_legend_handles_labels()\n",
    "# 只显示前10个feature，避免图例过长\n",
    "ax.legend(handles[:10], labels[:10], bbox_to_anchor=(1.05, 1), loc='upper left', title='Feature (Top 10)', fontsize=9)\n",
    "\n",
    "ax.set_title('变量重要性螺旋图', fontsize=16)\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "\n",
    "from matplotlib.colors import LinearSegmentedColormap\n",
    "from matplotlib.colorbar import ColorbarBase\n",
    "from matplotlib.colors import Normalize\n",
    "\n",
    "# 只绘制极坐标柱状图，配色为红色-蓝色渐变，去除所有背景和圆圈，图例为0-1区间\n",
    "\n",
    "\n",
    "# 创建红-蓝渐变色\n",
    "red_blue = LinearSegmentedColormap.from_list('red_blue', ['red', 'blue'])\n",
    "\n",
    "# 颜色映射（按重要性值归一化到0-1）\n",
    "normed_colors = red_blue(importances / importances.max())\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 10), subplot_kw={'projection': 'polar'})\n",
    "\n",
    "bars = ax.bar(angles, importances, width=width*0.9, color=normed_colors, edgecolor='none', alpha=0.95)\n",
    "\n",
    "# 添加feature标签\n",
    "for angle, bar, label in zip(angles, bars, variables):\n",
    "    ax.text(angle, bar.get_height() + 0.03, label, ha='center', va='bottom', fontsize=10, rotation=np.degrees(angle), rotation_mode='anchor')\n",
    "\n",
    "# 去除所有背景、圆圈和刻度\n",
    "ax.set_facecolor('none')\n",
    "fig.patch.set_facecolor('none')\n",
    "ax.grid(False)\n",
    "ax.set_yticklabels([])\n",
    "ax.set_xticklabels([])\n",
    "ax.spines['polar'].set_visible(False)\n",
    "\n",
    "# 添加颜色条作为图例，范围0-1\n",
    "\n",
    "cax = fig.add_axes([0.92, 0.25, 0.03, 0.5])\n",
    "cb = ColorbarBase(cax, cmap=red_blue, norm=Normalize(vmin=0, vmax=1), orientation='vertical')\n",
    "cb.set_label('Normalized Importance (0-1)', fontsize=12)\n",
    "\n",
    "plt.tight_layout(rect=[0, 0, 0.9, 1])\n",
    "plt.show()\n",
    "\n",
    "# 优化极坐标柱状图：更美观的字体、标签布局、颜色条、去除所有背景和圆圈\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(11, 11), subplot_kw={'projection': 'polar'})\n",
    "\n",
    "# 柱状图\n",
    "bars = ax.bar(\n",
    "    angles, importances, width=width*0.92, color=normed_colors, edgecolor='none', alpha=0.98\n",
    ")\n",
    "\n",
    "# 标签美化：标签沿半径外侧均匀分布，自动旋转角度，避免重叠\n",
    "for angle, bar, label in zip(angles, bars, variables):\n",
    "    rotation = np.degrees(angle)\n",
    "    alignment = 'left' if np.pi/2 < angle < 3*np.pi/2 else 'right'\n",
    "    ax.text(\n",
    "        angle, bar.get_height() + 0.06, label,\n",
    "        ha=alignment, va='center',\n",
    "        fontsize=12, fontweight='bold',\n",
    "        rotation=rotation if alignment == 'right' else rotation+180,\n",
    "        rotation_mode='anchor'\n",
    "    )\n",
    "\n",
    "# 去除所有背景、圆圈和刻度\n",
    "ax.set_facecolor('none')\n",
    "fig.patch.set_facecolor('none')\n",
    "ax.grid(False)\n",
    "ax.set_yticklabels([])\n",
    "ax.set_xticklabels([])\n",
    "ax.spines['polar'].set_visible(False)\n",
    "\n",
    "# 颜色条美化\n",
    "cax = fig.add_axes([0.93, 0.25, 0.025, 0.5])\n",
    "cb = ColorbarBase(cax, cmap=red_blue, norm=Normalize(vmin=0, vmax=1), orientation='vertical')\n",
    "cb.set_label('Normalized Importance (0-1)', fontsize=14, fontweight='bold')\n",
    "cb.ax.tick_params(labelsize=12)\n",
    "\n",
    "# 标题美化\n",
    "ax.set_title('Feature Importance (Polar Bar, Red-Blue, No Background)', fontsize=18, fontweight='bold', pad=30)\n",
    "\n",
    "plt.tight_layout(rect=[0, 0, 0.91, 1])\n",
    "plt.show()\n",
    "\n",
    "# 所有柱子等长，仅用颜色区分重要性，红色=高，蓝色=低，无标题\n",
    "\n",
    "# 颜色映射（红-蓝，红色为高，蓝色为低）\n",
    "normed_colors = red_blue(importances / importances.max())\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(11, 11), subplot_kw={'projection': 'polar'})\n",
    "\n",
    "# 所有柱子长度相同（如1.0）\n",
    "bar_length = 1.0\n",
    "bars = ax.bar(\n",
    "    angles, [bar_length]*len(variables), width=width*0.92, color=normed_colors, edgecolor='none', alpha=0.98\n",
    ")\n",
    "\n",
    "# 标签美化\n",
    "for angle, label in zip(angles, variables):\n",
    "    rotation = np.degrees(angle)\n",
    "    alignment = 'left' if np.pi/2 < angle < 3*np.pi/2 else 'right'\n",
    "    ax.text(\n",
    "        angle, bar_length + 0.06, label,\n",
    "        ha=alignment, va='center',\n",
    "        fontsize=12, fontweight='bold',\n",
    "        rotation=rotation if alignment == 'right' else rotation+180,\n",
    "        rotation_mode='anchor'\n",
    "    )\n",
    "\n",
    "# 去除所有背景、圆圈和刻度\n",
    "ax.set_facecolor('none')\n",
    "fig.patch.set_facecolor('none')\n",
    "ax.grid(False)\n",
    "ax.set_yticklabels([])\n",
    "ax.set_xticklabels([])\n",
    "ax.spines['polar'].set_visible(False)\n",
    "\n",
    "# 颜色条\n",
    "cax = fig.add_axes([0.93, 0.25, 0.025, 0.5])\n",
